{
  "name": "old-austin-grouch",
  "type": "module",
  "private": true,
  "version": "1.0.6",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "node -e \"if(!require('fs').existsSync('.setup-complete'))console.log('\\n⚠️  Run pnpm run setup before doing anything else! See AGENTS.md.\\n')\"",
    "typecheck": "npx nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "generate:favicons": "npx tsx tools/generate-favicons.ts",
    "prelint": "pnpm run build:plugins",
    "lint": "eslint .",
    "quality": "pnpm run lint && pnpm run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute nuxt-v4-template-db --local --file=drizzle/0000_initial_schema.sql",
    "db:studio": "drizzle-kit studio",
    "setup": "npx jiti tools/setup-analytics.ts status",
    "setup:all": "npx jiti tools/setup-analytics.ts all",
    "setup:posthog": "npx jiti tools/setup-analytics.ts posthog",
    "setup:ga": "npx jiti tools/setup-analytics.ts ga",
    "setup:gsc": "npx jiti tools/setup-analytics.ts gsc",
    "setup:gsc:verify": "npx jiti tools/setup-analytics.ts gsc:verify",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "predev": "node tools/check-setup.cjs",
    "prebuild": "node tools/check-setup.cjs",
    "predeploy": "node tools/check-setup.cjs",
    "update-layer": "npx tsx tools/update-layer.ts"
  },
  "dependencies": {
    "@nuxt/content": "^3.11.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/seo": "^3.4.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "nuxt": "^4.3.0",
    "posthog-js": "^1.205.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@iconify-json/lucide": "^1.2.94",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.11.4",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "googleapis": "^171.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "nuxt-og-image": "6.0.0-beta.42",
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@latest"
  },
  "volta": {
    "node": "22.14.0"
  },
  "packageManager": "pnpm@10.28.0"
}
