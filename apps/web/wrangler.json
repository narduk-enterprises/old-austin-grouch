{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/schemas/config/wrangler.json",
  "name": "old-austin-grouch",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public/",
    "binding": "ASSETS"
  },
  "compatibility_date": "2026-03-04",
  "compatibility_flags": [
    "nodejs_compat_v2"
  ],
  "routes": [
    {
      "pattern": "grouch.austin-texas.net",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "old-austin-grouch",
      "database_id": "02b8d140-719d-4dfa-b7b0-009083eab5f4"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "triggers": {
    "crons": [
      "0 10 * * 1"
    ]
  }
}
